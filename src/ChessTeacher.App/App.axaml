<Application
    x:Class="ChessTeacher.App.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="Background" Value="#111418" />
      <Setter Property="Foreground" Value="#F4F6F8" />
      <Setter Property="FontFamily" Value="Inter" />
    </Style>
    <Style Selector="Button.nav">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="16,11" />
      <Setter Property="Margin" Value="0,3" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Margin" Value="4" />
    </Style>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#1A1F25" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="16" />
    </Style>
  </Application.Styles>
</Application>
